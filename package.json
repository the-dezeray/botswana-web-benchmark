{
  "name": "bw-web-performance-auditor",
  "version": "1.0.0",
  "description": "Web performance auditor for Botswana company websites",
  "main": "audit.js",
  "scripts": {
    "audit": "node audit.js --sites sites.json --runs 3 --out results.json",
    "audit:5runs": "node audit.js --sites sites.json --runs 5 --out results.json",
    "audit:quick": "node audit.js --sites sites.json --runs 1 --out results_quick.json"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chrome-launcher": "^1.1.2",
    "lighthouse": "^12.0.0",
    "playwright": "^1.44.0"
  }
}
